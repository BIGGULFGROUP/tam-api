APP_NAME="The African Mail API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tam-api.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tam_api
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@theafricanmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Media storage — set to 's3' in production
MEDIA_DISK=public

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Admin secret for service-to-service requests from tam-admin
ADMIN_SECRET=

# CORS — tam-admin production URL
FRONTEND_URL=https://tam-admin.onrender.com

SANCTUM_STATEFUL_DOMAINS=tam-admin.onrender.com

# Phase 3 admin route isolation
# Frontend admin routes stay on the main API host by default unless overridden.
FRONTEND_ADMIN_API_DOMAIN=
BACKEND_ADMIN_API_DOMAIN=
FRONTEND_ADMIN_API_PREFIX=frontend-admin
BACKEND_ADMIN_API_PREFIX=backend-admin
